rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /circles/{circleId} {
      // Signed-in users can read circles (required to look up invite codes)
      // and create new ones with themselves as a member.
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.memberIds;
      // Members can update their circle. Non-members may update only to add
      // themselves (joining via invite code) without removing anyone.
      allow update: if request.auth != null
        && (request.auth.uid in resource.data.memberIds
            || (request.auth.uid in request.resource.data.memberIds
                && request.resource.data.memberIds.hasAll(resource.data.memberIds)));
      allow delete: if false;
    }
  }
}
